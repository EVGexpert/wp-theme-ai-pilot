{
    "$schema":  "https://schemas.wp.org/trunk/block.json",
    "apiVersion":  3,
    "name":  "aipilot-demo-blocks/process-list",
    "title":  "Process List",
    "category":  "aipilot-demo",
    "icon":  "list-view",
    "description":  "Process steps list",
    "textdomain":  "aipilot-demo",
    "supports":  {
                     "anchor":  true,
                     "align":  [
                                   "wide"
                               ],
                     "spacing":  {
                                     "margin":  true,
                                     "padding":  true,
                                     "blockGap":  true
                                 },
                     "color":  {
                                   "background":  true
                               }
                 },
    "attributes":  {
                       "showDividers":  {
                                            "type":  "boolean",
                                            "default":  true
                                        },
                       "showNumbers":  {
                                           "type":  "boolean",
                                           "default":  true
                                       },
                       "gap":  {
                                   "type":  "string",
                                   "default":  "32px"
                               }
                   },
    "style":  "file:../blocks.css",
    "render":  "file:./render.php"
}