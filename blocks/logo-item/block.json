{
    "$schema":  "https://schemas.wp.org/trunk/block.json",
    "apiVersion":  3,
    "name":  "aipilot-demo-blocks/logo-item",
    "title":  "Logo Item",
    "category":  "aipilot-demo",
    "icon":  "format-image",
    "description":  "Single partner logo",
    "textdomain":  "aipilot-demo",
    "parent":  [
                   "aipilot-demo-blocks/logo-strip"
               ],
    "supports":  {
                     "anchor":  true,
                     "spacing":  {
                                     "margin":  true
                                 }
                 },
    "attributes":  {
                       "logoImageId":  {
                                           "type":  "number"
                                       },
                       "logoImageUrl":  {
                                            "type":  "string"
                                        },
                       "alt":  {
                                   "type":  "string",
                                   "default":  ""
                               },
                       "companyName":  {
                                           "type":  "string",
                                           "default":  ""
                                       },
                       "linkUrl":  {
                                       "type":  "string",
                                       "default":  ""
                                   },
                       "monochrome":  {
                                          "type":  "boolean",
                                          "default":  true
                                      }
                   },
    "style":  "file:../blocks.css",
    "render":  "file:./render.php"
}