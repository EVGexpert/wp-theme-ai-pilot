{
    "$schema":  "https://schemas.wp.org/trunk/block.json",
    "apiVersion":  3,
    "name":  "aipilot-demo-blocks/property-card",
    "title":  "Property Card",
    "category":  "aipilot-demo",
    "icon":  "building",
    "description":  "Single property card",
    "textdomain":  "aipilot-demo",
    "supports":  {
                     "anchor":  true,
                     "spacing":  {
                                     "margin":  true,
                                     "padding":  true
                                 },
                     "color":  {
                                   "background":  true
                               }
                 },
    "attributes":  {
                        "propertyId":  {
                                           "type":  "number"
                                       },
                        "variant":  {
                                        "type":  "string",
                                        "default":  "detailed"
                                    },
                       "showArea":  {
                                        "type":  "boolean",
                                        "default":  true
                                    },
                       "showPrice":  {
                                         "type":  "boolean",
                                         "default":  true
                                     },
                       "showAddress":  {
                                           "type":  "boolean",
                                           "default":  true
                                       },
                       "showExcerpt":  {
                                           "type":  "boolean",
                                           "default":  false
                                       },
                       "showBadge":  {
                                         "type":  "boolean",
                                         "default":  true
                                     }
                   },
    "style":  "file:../blocks.css",
    "render":  "file:./render.php"
}