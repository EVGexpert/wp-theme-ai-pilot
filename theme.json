{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "title": "AIPilot Demo",
  "description": "Блочная тема для агентства коммерческой недвижимости",
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "color": {
      "palette": [
        { "slug": "primary", "name": "Основной голубой", "color": "#86AEC8" },
        { "slug": "primary-dark", "name": "Тёмно-голубой", "color": "#5E8FAA" },
        { "slug": "primary-light", "name": "Светло-голубой", "color": "#D4E4ED" },
        { "slug": "text", "name": "Основной текст", "color": "#202020" },
        { "slug": "text-secondary", "name": "Вторичный текст", "color": "#6F7377" },
        { "slug": "surface", "name": "Белый", "color": "#FFFFFF" },
        { "slug": "surface-soft", "name": "Светлый фон", "color": "#F5F6F7" },
        { "slug": "border", "name": "Граница", "color": "#E2E4E6" },
        { "slug": "dark", "name": "Тёмная секция", "color": "#252525" },
        { "slug": "dark-text", "name": "Светлый текст на тёмном", "color": "#F0F0F0" }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "slug": "inter",
          "name": "Inter",
          "fontFace": [
            { "fontFamily": "Inter", "fontWeight": "400", "fontStyle": "normal", "src": ["file:./assets/fonts/inter-regular.ttf"] },
            { "fontFamily": "Inter", "fontWeight": "500", "fontStyle": "normal", "src": ["file:./assets/fonts/inter-medium.ttf"] },
            { "fontFamily": "Inter", "fontWeight": "600", "fontStyle": "normal", "src": ["file:./assets/fonts/inter-semibold.ttf"] },
            { "fontFamily": "Inter", "fontWeight": "700", "fontStyle": "normal", "src": ["file:./assets/fonts/inter-bold.ttf"] }
          ]
        }
      ],
      "fontSizes": [
        { "slug": "xs", "size": "0.75rem", "name": "XSmall" },
        { "slug": "sm", "size": "0.875rem", "name": "Small" },
        { "slug": "md", "size": "1rem", "name": "Medium" },
        { "slug": "lg", "size": "1.125rem", "name": "Large" },
        { "slug": "xl", "size": "1.25rem", "name": "XLarge" },
        { "slug": "2xl", "size": "1.5rem", "name": "2XLarge" },
        { "slug": "3xl", "size": "1.75rem", "name": "3XLarge" },
        { "slug": "4xl", "size": "2.25rem", "name": "4XLarge" },
        { "slug": "5xl", "size": "3rem", "name": "5XLarge" }
      ]
    },
    "spacing": {
      "spacingSizes": [
        { "slug": "xs", "size": "0.5rem", "name": "XSmall" },
        { "slug": "sm", "size": "0.75rem", "name": "Small" },
        { "slug": "md", "size": "1rem", "name": "Medium" },
        { "slug": "lg", "size": "1.5rem", "name": "Large" },
        { "slug": "xl", "size": "2rem", "name": "XLarge" },
        { "slug": "2xl", "size": "3rem", "name": "2XLarge" },
        { "slug": "3xl", "size": "4rem", "name": "3XLarge" },
        { "slug": "4xl", "size": "6rem", "name": "4XLarge" },
        { "slug": "5xl", "size": "8rem", "name": "5XLarge" }
      ]
    },
    "border": {
      "radius": true,
      "radiusSizes": [
        { "slug": "sm", "name": "Small", "size": "8px" },
        { "slug": "md", "name": "Medium", "size": "14px" },
        { "slug": "lg", "name": "Large", "size": "22px" },
        { "slug": "pill", "name": "Pill", "size": "999px" }
      ]
    },
    "layout": { "contentSize": "760px", "wideSize": "1180px" },
    "dimensions": { "minHeight": true },
    "position": { "sticky": true },
    "lightbox": { "enabled": true, "allowEditing": true },
    "custom": {
      "aipilot-container": "1180px",
      "aipilot-gutter-desktop": "32px",
      "aipilot-gutter-tablet": "24px",
      "aipilot-gutter-mobile": "16px",
      "aipilot-section-space": "96px",
      "aipilot-section-space-tablet": "72px",
      "aipilot-section-space-mobile": "56px",
      "aipilot-radius-card": "14px",
      "aipilot-radius-large": "22px",
      "aipilot-text-muted": "#707579",
      "aipilot-border": "#e6e8ea"
    }
  },
  "styles": {
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--inter)",
      "fontSize": "var(--wp--preset--font-size--md)",
      "lineHeight": "1.6"
    },
    "color": {
      "background": "var(--wp--preset--color--surface)",
      "text": "var(--wp--preset--color--text)"
    },
    "elements": {
      "h1": { "typography": { "fontSize": "clamp(2.25rem, 5vw, 3.5rem)", "fontWeight": "700", "lineHeight": "1.15" } },
      "h2": { "typography": { "fontSize": "clamp(1.75rem, 4vw, 2.5rem)", "fontWeight": "600", "lineHeight": "1.2" } },
      "h3": { "typography": { "fontSize": "clamp(1.25rem, 3vw, 1.5rem)", "fontWeight": "600", "lineHeight": "1.3" } },
      "button": {
        "border": { "radius": "999px" },
        "typography": { "fontSize": "var(--wp--preset--font-size--sm)", "fontWeight": "600" },
        "color": { "text": "var(--wp--preset--color--surface)", "background": "var(--wp--preset--color--primary)" },
        ":hover": { "color": { "text": "var(--wp--preset--color--surface)", "background": "var(--wp--preset--color--primary-dark)" } },
        ":focus": { "color": { "text": "var(--wp--preset--color--surface)", "background": "var(--wp--preset--color--primary-dark)" } }
      },
      "input": {
        "border": { "color": "var(--wp--preset--color--border)", "radius": "8px", "width": "1px" },
        "color": { "text": "var(--wp--preset--color--text)", "background": "var(--wp--preset--color--surface)" },
        "spacing": { "padding": { "top": "0.5rem", "bottom": "0.5rem", "left": "0.75rem", "right": "0.75rem" } }
      },
      "link": {
        "color": { "text": "var(--wp--preset--color--primary-dark)" },
        ":hover": { "color": { "text": "var(--wp--preset--color--text)" } }
      }
    },
    "blocks": {
      "core/group": { "spacing": { "blockGap": "var(--wp--preset--spacing--lg)" } },
      "core/navigation": { "typography": { "fontSize": "var(--wp--preset--font-size--sm)", "fontWeight": "500" } },
      "core/site-title": { "typography": { "fontSize": "var(--wp--preset--font-size--xl)", "fontWeight": "700" } },
      "core/button": { "spacing": { "padding": { "top": "0.75rem", "bottom": "0.75rem", "left": "1.5rem", "right": "1.5rem" } } },
      "core/image": { "border": { "radius": "14px" } },
      "core/separator": { "color": { "text": "var(--wp--preset--color--border)" } },
      "core/post-content": { "spacing": { "padding": { "top": "0", "bottom": "0" } } }
    },
    "spacing": { "blockGap": "var(--wp--preset--spacing--lg)" }
  },
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" }
  ]
}
